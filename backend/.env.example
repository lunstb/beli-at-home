# Google OAuth client ID for authentication
GOOGLE_CLIENT_ID=your-google-client-id-here

# JWT signing secret - MUST be changed in production
JWT_SECRET=dev-secret-change-me-in-production

# Port the backend server listens on
PORT=3001

# Allowed frontend origins (comma-separated for multiple)
# e.g. http://localhost:5173,https://yourusername.github.io
FRONTEND_URL=http://localhost:5173

# Storage mode: "local" (filesystem) or "s3" (S3/MinIO)
STORAGE_MODE=local

# S3/MinIO configuration (only used when STORAGE_MODE=s3)
# For MinIO local dev: http://localhost:9000
# For AWS S3 production: https://s3.us-east-1.amazonaws.com (or omit to use default)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=beli-at-home
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Set to true for MinIO/path-style access, false for AWS S3 virtual-hosted style
S3_FORCE_PATH_STYLE=true

# DB backup to S3 (only used when STORAGE_MODE=s3)
DB_BACKUP_BUCKET=beli-at-home-backups
DB_BACKUP_INTERVAL_HOURS=6
